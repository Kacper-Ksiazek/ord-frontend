{
	"name": "ord-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"aggregate": "tsx scripts/aggregate-translations.ts",
		"predev": "npm run aggregate",
		"dev": "vite dev",
		"prebuild": "npm run aggregate",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"test:e2e": "playwright test --config e2e/playwright.config.ts",
		"test:e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
		"test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
		"test:e2e:install": "playwright install chromium",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"prelint": "svelte-kit sync",
		"lint": "eslint . --report-unused-disable-directives",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"lint-staged": {
		"*.svelte": [
			"prettier --write",
			"eslint --fix"
		],
		"*.{js,ts}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.json": "prettier --write"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^4.1.2",
		"@flowbite-svelte-plugins/chart": "^0.2.4",
		"@inlang/paraglide-js": "^2.4.0",
		"@storybook/addon-a11y": "^10.0.2",
		"@storybook/addon-docs": "^10.0.2",
		"@storybook/addon-svelte-csf": "^5.0.10",
		"@storybook/addon-vitest": "^10.0.2",
		"@storybook/sveltekit": "^10.0.2",
		"@sveltejs/adapter-vercel": "^6.0.0",
		"@sveltejs/kit": "^2.47.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.14",
		"@types/lodash": "^4.17.20",
		"@types/node": "^22",
		"@typescript-eslint/eslint-plugin": "^8.48.0",
		"@typescript-eslint/parser": "^8.48.0",
		"@vitest/browser": "^3.2.4",
		"eslint": "^9.39.1",
		"eslint-plugin-svelte": "^3.13.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.6",
		"@playwright/test": "^1.56.1",
		"dotenv": "^16.5.0",
		"playwright": "^1.56.1",
		"prettier": "^3.7.1",
		"prettier-plugin-svelte": "^3.4.0",
		"storybook": "^10.0.2",
		"svelte": "^5.41.0",
		"svelte-check": "^4.3.3",
		"tailwindcss": "^4.1.14",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"vite": "^7.1.10",
		"vitest": "^3.2.4",
		"vitest-browser-svelte": "^1.1.0"
	},
	"dependencies": {
		"@kacper-ksiazek/ord-api-types": "^1.0.37",
		"@tanstack/svelte-hotkeys": "^0.9.1",
		"@tanstack/svelte-query": "^6.0.5",
		"axios": "^1.13.2",
		"flowbite": "^3.1.2",
		"flowbite-svelte": "^1.20.1",
		"gravatar-url": "^4.0.1",
		"lodash": "^4.17.21",
		"lucide-svelte": "^0.562.0",
		"rxjs": "^7.8.2",
		"tailwind-merge": "^3.4.0",
		"typescript-eslint": "^8.48.0"
	}
}

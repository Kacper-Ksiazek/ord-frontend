{
	"name": "ord-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check:biome": "biome check .",
		"fix": "biome check --write ."
	},
	"lint-staged": {
		"*": "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.3",
		"@chromatic-com/storybook": "^4.1.2",
		"@inlang/paraglide-js": "^2.4.0",
		"@storybook/addon-a11y": "^10.0.2",
		"@storybook/addon-docs": "^10.0.2",
		"@storybook/addon-svelte-csf": "^5.0.10",
		"@storybook/addon-vitest": "^10.0.2",
		"@storybook/sveltekit": "^10.0.2",
		"@sveltejs/adapter-vercel": "^6.0.0",
		"@sveltejs/kit": "^2.47.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.14",
		"@types/node": "^22",
		"@vitest/browser": "^3.2.4",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.6",
		"playwright": "^1.56.1",
		"storybook": "^10.0.2",
		"svelte": "^5.41.0",
		"svelte-check": "^4.3.3",
		"tailwindcss": "^4.1.14",
		"typescript": "^5.9.3",
		"vite": "^7.1.10",
		"vitest": "^3.2.4",
		"vitest-browser-svelte": "^1.1.0"
	},
	"dependencies": {
		"flowbite": "^3.1.2",
		"flowbite-svelte": "^1.20.1",
		"flowbite-svelte-icons": "^3.0.0"
	}
}

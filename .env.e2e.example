# E2E test environment — copy to .env.e2e and fill in values.
# Load before running: copy to .env.e2e (loaded automatically by playwright.config.ts)

# Frontend URL (Playwright baseURL)
E2E_BASE_URL=http://localhost:5173

# Backend API URL (passed to dev server as PUBLIC_API_URL)
E2E_API_URL=http://localhost:8080

# Test user email registered in the backend
E2E_TEST_EMAIL=e2e-test@example.com

# Option A: fixed OTP code (test/dev backend that accepts a known code)
E2E_OTP_CODE=000000

# Option B: HTTP endpoint returning latest OTP as JSON { "code": "123456" }
# E2E_OTP_FETCH_URL=http://localhost:8080/api/v1/test/otp

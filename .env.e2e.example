# E2E test environment — copy to .env.e2e at the repo root.
# Loaded automatically by e2e/fixtures/test-env.ts on import (via dotenv).
#
# Standard dotenv syntax: KEY=value, optional quotes, export prefix, # comments.

# Frontend URL (Playwright baseURL)
E2E_BASE_URL=http://localhost:5173

# Backend API URL (passed to dev server as PUBLIC_API_URL)
E2E_API_URL=http://localhost:8080

# Test user email — must match OTP_WHITELISTED_EMAILS on the backend
E2E_TEST_EMAIL=e2e-ci@ord.test

# Fixed OTP code — must match OTP_CODE_FOR_WHITELISTED_EMAILS on the backend
E2E_OTP_CODE=123456
